# ==============================================================================
# SafeTrace — Task 1 (serverful) deployment configuration
# Edit these values, then run ./deploy.sh
# ==============================================================================

# --- Core ---------------------------------------------------------------------
export PROJECT="${PROJECT:-safetrace}"
export AWS_REGION="${AWS_REGION:-us-east-1}"

# --- GitHub repository the EC2 bootstrap script clones ------------------------
# IMPORTANT: point this at YOUR fork/repo.
export REPO_URL="${REPO_URL:-https://github.com/gokulupadhyayguragain/ddac-assignment.git}"

# --- Network ------------------------------------------------------------------
export VPC_CIDR="${VPC_CIDR:-10.0.0.0/16}"
export PUBLIC_SUBNET_CIDRS="${PUBLIC_SUBNET_CIDRS:-10.0.0.0/20 10.0.16.0/20}"
export PRIVATE_SUBNET_CIDRS="${PRIVATE_SUBNET_CIDRS:-10.0.128.0/20 10.0.144.0/20}"
# Set to "true" to place instances in PUBLIC subnets and skip the NAT Gateway
# (cheaper lab option). "false" uses private subnets + 1 NAT Gateway.
export USE_PUBLIC_INSTANCES="${USE_PUBLIC_INSTANCES:-false}"

# --- Database (RDS PostgreSQL) ------------------------------------------------
export DB_NAME="${DB_NAME:-safetrace}"
export DB_USERNAME="${DB_USERNAME:-safetrace}"
# REQUIRED: set a strong password before deploying (8+ chars, no '/@" ' or spaces).
export DB_PASSWORD="${DB_PASSWORD:-}"
export DB_INSTANCE_CLASS="${DB_INSTANCE_CLASS:-db.t3.micro}"
export DB_ALLOCATED_STORAGE="${DB_ALLOCATED_STORAGE:-20}"
export DB_ENGINE_VERSION="${DB_ENGINE_VERSION:-16.4}"
export DB_MULTI_AZ="${DB_MULTI_AZ:-false}"

# --- Compute (EC2 Auto Scaling Group) -----------------------------------------
export INSTANCE_TYPE="${INSTANCE_TYPE:-t3.small}"
export ROOT_VOLUME_GB="${ROOT_VOLUME_GB:-20}"
export ASG_MIN="${ASG_MIN:-2}"
export ASG_DESIRED="${ASG_DESIRED:-2}"
export ASG_MAX="${ASG_MAX:-4}"
export CPU_TARGET="${CPU_TARGET:-60}"

# --- Application secrets (stored in AWS Secrets Manager) ----------------------
export SECRET_NAME="${SECRET_NAME:-safetrace/prod/app}"
# A long random JWT secret. Auto-generated if left blank.
export JWT_SECRET="${JWT_SECRET:-}"
# Return the email verification code in API responses (handy for the demo).
export AUTH_DEV_EXPOSE_VERIFICATION_CODE="${AUTH_DEV_EXPOSE_VERIFICATION_CODE:-true}"

# --- Resource names (rarely need changing) ------------------------------------
export STATE_FILE="${STATE_FILE:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/.state.env}"
